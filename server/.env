# Opción B — MySQL con Prisma (producción / Vercel)
# Descomenta la línea de abajo y comenta DATA_FILE cuando tengas tu DB lista.
# Vercel NO puede escribir al disco, así que en producción MySQL es obligatorio.
#
# DATABASE_URL="mysql://USUARIO:CONTRASEÑA@HOST:PUERTO/envirogest"
#
# Ejemplos por proveedor:
#   PlanetScale : mysql://usuario:pass@aws.connect.psdb.cloud/envirogest?sslaccept=strict
#   Railway     : mysql://root:pass@containers-us-west-X.railway.app:PORT/railway
#   TiDB Cloud  : mysql://user:pass@gateway01.us-east-1.prod.aws.tidbcloud.com:4000/envirogest?ssl=true
#   Aiven       : mysql://avnadmin:pass@mysql-XXX.aivencloud.com:PORT/defaultdb?ssl-mode=REQUIRED
#   Local       : mysql://root:@localhost:3306/envirogest
