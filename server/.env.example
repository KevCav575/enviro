PORT=3001

# Genera con: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=CHANGE_ME_use_a_long_random_string_minimum_32_chars

NODE_ENV=production
CORS_ORIGIN=http://localhost:5173

# ── Almacenamiento ────────────────────────────────────────────────────────────
# Opción A: JSON file (desarrollo sin base de datos)
DATA_FILE=./data/users.json

# Opción B: MySQL con Prisma (producción)
# Comenta DATA_FILE y descomenta DATABASE_URL cuando esté listo.
# DATABASE_URL="mysql://usuario:contraseña@localhost:3306/envirogest"

# Pasos para migrar a MySQL:
#   1. Configurar DATABASE_URL
#   2. cd server && npm install @prisma/client prisma
#   3. npx prisma migrate deploy
#   4. Actualizar imports en routes/auth.ts y routes/users.ts
#      para usar db/userRepository en lugar de db/store
